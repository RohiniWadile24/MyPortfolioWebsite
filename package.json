{
  "name": "fullstack-portfolio",
  "version": "1.0.0",
  "description": "Full Stack Developer Portfolio",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "server": "nodemon src/server.js"
    "client": "serve frontend -p 3000",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run open\"",
    "open": "wait-on http-get://localhost:3000 && start http://localhost:3000",
    "seed": "node backend/seed.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "mongoose": "^7.6.3",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "open-cli": "^9.0.0",
    "serve": "^14.2.1",
    "wait-on": "^9.0.10"
  }
}
